# Discord Webhooks (optional - for error logging in production)
VITE_DISCORD_WEBHOOK_ERRORS=https://discord.com/api/webhooks/your_errors_webhook
VITE_DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/your_critical_webhook

# Contact form (Web3Forms) - get a free access key at https://web3forms.com
# Register with hello@rnltlabs.de so submissions land in that inbox.
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# App Version
VITE_APP_VERSION=1.0.3
